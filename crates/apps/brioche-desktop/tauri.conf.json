{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "Brioche Desktop",
  "version": "0.1.0",
  "identifier": "com.brioche.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "./frontend/dist",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Brioche Desktop",
        "width": 900,
        "height": 700,
        "minWidth": 480,
        "minHeight": 500,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-eval'; img-src 'self' data:; connect-src 'self' ipc:;"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
